{
  "manifest_version": 3,
  "name": "ORII Calendar Assistant",
  "version": "1.0.6",
  "description": "AI-powered calendar assistant with native Chrome side panel integration",
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_title": "Open ORII Calendar Assistant",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "permissions": ["sidePanel", "activeTab", "storage", "identity"],
  "host_permissions": [
    "https://*.railway.app/*",
    "http://localhost:*/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "{{GOOGLE_CLIENT_ID}}",
    "scopes": [
      "https://www.googleapis.com/auth/calendar",
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}
